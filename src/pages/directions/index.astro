---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { entryUrl, formatDate } from '../../utils/content';
import { researchDirections } from '../../data/researchDirections';

const entries = (await getCollection('research', ({ data }) => import.meta.env.PROD ? data.draft !== true : true))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const cards = researchDirections.map((direction) => {
  const articles = entries
    .filter((entry) => entry.data.direction === direction.slug)
    .map((entry) => ({
      href: entryUrl('research', entry.id),
      title: entry.data.title,
      description: entry.data.description,
      date: formatDate(entry.data.pubDate)
    }));

  return {
    ...direction,
    count: entries.filter((entry) => entry.data.direction === direction.slug).length,
    articles
  };
});
---

<BaseLayout title="文章索引" description="按具身智能技术方向整理论文、算法和项目笔记。">
  <section class="listing-hero shell">
    <h1>文章索引</h1>
  </section>

  <nav class="shell direction-quick-nav" aria-label="方向快速索引">
    {cards.map((card) => (
      <a href={`#${card.slug}`} style={`--module-color: ${card.color}`}>
        <strong>{card.label}</strong>
        <em>{card.count}</em>
      </a>
    ))}
  </nav>

  <section class="shell listing-section">
    <div class="direction-grid">
      {cards.map((card) => (
        <article id={card.slug} class="direction-card" style={`--module-color: ${card.color}`}>
          <div class="direction-card-intro">
            <a class="direction-card-head" href={`/directions/${card.slug}/`} aria-label={`查看${card.label}`}>
              <h2>{card.label}</h2>
              <i aria-hidden="true">↗</i>
            </a>
            <p>{card.description}</p>
            <div class="direction-card-meta">{card.count > 0 ? `${card.count} 篇内容` : '内容整理中'}</div>
          </div>
          {card.articles.length > 0 && (
            <div class="direction-latest">
              {card.articles.map((entry) => (
                <a href={entry.href}>
                  <span>{entry.date}</span>
                  <strong>{entry.title}</strong>
                </a>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
