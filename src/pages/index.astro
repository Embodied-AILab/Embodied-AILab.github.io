---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { entryUrl, formatDate } from '../utils/content';
import { researchDirections } from '../data/researchDirections';
import VisitorCounter from '../components/VisitorCounter.astro';

const filter = ({ data }: { data: { draft?: boolean } }) => import.meta.env.PROD ? data.draft !== true : true;
const [research, projects] = await Promise.all([
  getCollection('research', filter),
  getCollection('projects', filter)
]);

const directionBySlug = new Map(researchDirections.map((direction) => [direction.slug, direction.label]));
const latestEntries = [
  ...research.map((entry) => ({
    href: entryUrl('research', entry.id),
    title: entry.data.title,
    description: entry.data.description,
    date: formatDate(entry.data.pubDate),
    timestamp: entry.data.pubDate.valueOf(),
    category: directionBySlug.get(entry.data.direction) ?? '研究笔记',
    tone: 'research'
  })),
  ...projects.map((entry) => ({
    href: entryUrl('projects', entry.id),
    title: entry.data.title,
    description: entry.data.description,
    date: formatDate(entry.data.pubDate),
    timestamp: entry.data.pubDate.valueOf(),
    category: '项目复现',
    tone: 'project'
  }))
].sort((a, b) => b.timestamp - a.timestamp);

const allEntries = [...research, ...projects];
const updateCounts = new Map<string, number>();
allEntries.forEach((entry) => {
  const date = entry.data.pubDate.toISOString().slice(0, 10);
  updateCounts.set(date, (updateCounts.get(date) ?? 0) + 1);
});

const latestDate = allEntries
  .map((entry) => entry.data.pubDate)
  .sort((a, b) => b.valueOf() - a.valueOf())[0] ?? new Date();
const endDate = new Date(latestDate);
endDate.setHours(0, 0, 0, 0);
endDate.setDate(endDate.getDate() + (6 - endDate.getDay()));
const startDate = new Date(endDate);
startDate.setDate(endDate.getDate() - 181);

const contributionDays = Array.from({ length: 182 }, (_, index) => {
  const date = new Date(startDate);
  date.setDate(startDate.getDate() + index);
  const key = date.toISOString().slice(0, 10);
  const count = updateCounts.get(key) ?? 0;
  const level = count === 0 ? 0 : Math.min(count, 4);
  return {
    key,
    date: formatDate(date),
    count,
    level
  };
});

const activeDays = contributionDays.filter((day) => day.count > 0).length;
const totalUpdates = contributionDays.reduce((sum, day) => sum + day.count, 0);
const contributionWeeks = Array.from({ length: 26 }, (_, weekIndex) =>
  contributionDays.slice(weekIndex * 7, weekIndex * 7 + 7)
);
const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const monthLabels = contributionWeeks.map((week) => {
  const monthStart = week.find((day) => Number(day.key.split('-')[2]) === 1);
  if (!monthStart) return '';
  const month = Number(monthStart.key.split('-')[1]);
  return monthNames[month - 1];
});
---

<BaseLayout>
  <section class="home-lab shell">
    <section class="home-hero" aria-label="EAI-Lab 主页">
      <div class="home-hero-copy">
        <p class="home-eyebrow">EAI-Lab · Embodied AI Notes</p>
        <h1>具身智能研究室</h1>
        <p class="home-deck">按技术问题整理机器人运动控制、视觉强化学习、AMP、世界模型与项目复现，把论文里的算法流程拆成能复用的工程笔记。</p>
        <div class="home-hero-actions">
          <a class="button primary" href="/directions/">文章索引 <span>↗</span></a>
          <a class="button ghost" href="/search/">站内搜索 <span>↗</span></a>
        </div>
      </div>

      <div class="home-hero-side" aria-label="最近更新记录">
        <div class="home-side-head">
          <span>更新记录</span>
          <a href="/directions/">全部内容 ↗</a>
        </div>
        <div class="home-contrib-card">
          <div class="home-contrib-summary">
            <strong>近 6 个月 {totalUpdates} 次内容更新</strong>
          </div>
          <div class="home-contrib-calendar">
            <div class="home-contrib-months" aria-hidden="true">
              <span></span>
              {monthLabels.map((label) => <span>{label}</span>)}
            </div>
            <div class="home-contrib-body">
              <div class="home-contrib-weekdays" aria-hidden="true">
                <span></span>
                <span>Mon</span>
                <span></span>
                <span>Wed</span>
                <span></span>
                <span>Fri</span>
                <span></span>
              </div>
              <div class="home-contrib-grid" aria-label="最近 6 个月内容更新热力图">
                {contributionWeeks.map((week) => (
                  <div class="home-contrib-week">
                    {week.map((day) => (
                      <span data-level={day.level} title={`${day.date}：${day.count} 条更新`} aria-label={`${day.date}：${day.count} 条更新`}></span>
                    ))}
                  </div>
                ))}
              </div>
            </div>
          </div>
          <div class="home-contrib-foot">
            <span>{activeDays} 天有更新 · 统计已发布研究笔记和项目记录</span>
            <div class="home-contrib-legend" aria-label="更新频率图例">
              <i>少</i>
              <b data-level="0"></b>
              <b data-level="1"></b>
              <b data-level="2"></b>
              <b data-level="3"></b>
              <b data-level="4"></b>
              <i>多</i>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="home-insight-row" aria-label="站点动态">
      <div class="home-counter-section" aria-label="点击量统计">
        <VisitorCounter />
      </div>
      <article class="home-latest-panel" aria-label="最新文章">
        <div class="home-latest-head">
          <div>
            <span>内容入口</span>
            <h2>最新文章</h2>
          </div>
          <a href="/directions/">全部内容 ↗</a>
        </div>
        <div class="home-latest-list">
          {latestEntries.map((entry, index) => (
            <a class:list={['home-latest-item', entry.tone]} href={entry.href}>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <div>
                <small>{entry.date} · {entry.category}</small>
                <strong>{entry.title}</strong>
                <p>{entry.description}</p>
              </div>
            </a>
          ))}
        </div>
      </article>
    </section>
  </section>
</BaseLayout>
