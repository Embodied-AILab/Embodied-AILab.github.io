---
import BaseLayout from '../layouts/BaseLayout.astro';

const modules = [
  { href: '/papers/', title: '论文精读', tone: 'paper' },
  { href: '/agents/', title: 'Agent 实践', tone: 'agent' },
  { href: '/projects/', title: '项目复现', tone: 'project' },
  { href: '/about/', title: '关于这个网站', tone: 'about' }
];
---

<BaseLayout>
  <section class="home-lab shell">
    <div class="home-profile">
      <div class="profile-avatar">
        <img src="/avatar.jpg" alt="EAI-Lab 头像" loading="eager" />
      </div>
      <div class="home-profile-copy">
        <p>EAI-Lab</p>
        <h1>具身智能研究室</h1>
      </div>
    </div>

    <nav class="home-index" aria-label="首页入口">
      {modules.map((item) => (
        <a class:list={['home-module', item.tone]} href={item.href} aria-label={`进入${item.title}`}>
          <h2>{item.title}</h2>
          <span aria-hidden="true">↗</span>
        </a>
      ))}
    </nav>
  </section>
</BaseLayout>
