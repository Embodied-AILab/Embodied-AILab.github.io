---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { entryUrl, formatDate, sectionMeta } from '../utils/content';

const filter = ({ data }: any) => import.meta.env.PROD ? data.draft !== true : true;
const [papers, agents, projects] = await Promise.all([
  getCollection('papers', filter),
  getCollection('agents', filter),
  getCollection('projects', filter)
]);

const allEntries = [
  ...papers.map((entry) => ({ entry, collection: 'papers' as const })),
  ...agents.map((entry) => ({ entry, collection: 'agents' as const })),
  ...projects.map((entry) => ({ entry, collection: 'projects' as const }))
].sort((a, b) => b.entry.data.pubDate.valueOf() - a.entry.data.pubDate.valueOf());

const featured = allEntries.filter((item) => item.entry.data.featured);
const latest = (featured.length >= 4 ? featured : allEntries).slice(0, 6);
const lead = latest[0];
const secondary = latest.slice(1, 4);
---

<BaseLayout>
  <section class="home-hero shell">
    <div class="hero-copy">
      <div class="hero-kicker"><span>EMBODIED INTELLIGENCE</span><i></i><span>AGENTIC ENGINEERING</span></div>
      <h1>把复杂论文读透，<br /><em>把真实项目做实。</em></h1>
      <p>EAI-Lab 聚焦具身智能、人形机器人与 AI Agent 工程实践，持续整理优质论文、算法实现、项目复现和 Vibe Coding 工作流。</p>
      <div class="hero-actions">
        <a class="button primary" href="/papers/">进入论文精读 <span>↗</span></a>
        <a class="button ghost" href="/about/">了解 EAI-Lab</a>
      </div>
      <div class="hero-meta">
        <div><b>{papers.length}</b><span>PAPERS</span><small>论文精读</small></div>
        <div><b>{agents.length}</b><span>AGENTS</span><small>Agent 实践</small></div>
        <div><b>{projects.length}</b><span>PROJECTS</span><small>项目复现</small></div>
      </div>
    </div>

    <div class="hero-desk" aria-label="研究方向概览">
      <div class="desk-head">
        <span>RESEARCH DESK / 2026</span>
        <i><b></b>持续更新</i>
      </div>
      <div class="desk-orbit" aria-hidden="true">
        <span class="orbit-ring ring-one"></span>
        <span class="orbit-ring ring-two"></span>
        <span class="orbit-core">EAI</span>
        <span class="orbit-node node-one">Humanoid</span>
        <span class="orbit-node node-two">Sim2Real</span>
        <span class="orbit-node node-three">Agent</span>
        <span class="orbit-node node-four">Control</span>
      </div>
      <div class="desk-list">
        <div><span>01</span><b>人形机器人控制</b><small>Locomotion · Whole-body</small></div>
        <div><span>02</span><b>机器人学习</b><small>RL · Imitation · Sim-to-Real</small></div>
        <div><span>03</span><b>AI Agent 工程</b><small>Vibe Coding · Workflow</small></div>
      </div>
    </div>
  </section>

  <section class="manifesto-band">
    <div class="shell manifesto-inner">
      <span>READ DEEPLY</span>
      <p>不复述摘要，不堆砌术语。优先回答：<strong>为什么这样设计、算法如何运行、实现最容易出什么问题。</strong></p>
      <span>BUILD HONESTLY</span>
    </div>
  </section>

  <section class="portal-section shell">
    <SectionHeader eyebrow="01 / EXPLORE" title="三个内容入口" description="围绕研究、工具与工程实践，形成可持续积累的中文知识库。" />
    <div class="portal-grid">
      <a class="portal-card paper" href="/papers/">
        <div class="portal-top"><span>01</span><b>↗</b></div>
        <div class="portal-symbol">P</div>
        <h3>论文精读</h3>
        <p>从研究问题出发，拆解方法、训练流程、实验设计和具体实现。</p>
        <small>PAPERS / RESEARCH NOTES</small>
      </a>
      <a class="portal-card agent" href="/agents/">
        <div class="portal-top"><span>02</span><b>↗</b></div>
        <div class="portal-symbol">A</div>
        <h3>Agent 实践</h3>
        <p>记录 AI Agent、Vibe Coding 和自动化工作流中的真实经验。</p>
        <small>AGENTS / VIBE CODING</small>
      </a>
      <a class="portal-card project" href="/projects/">
        <div class="portal-top"><span>03</span><b>↗</b></div>
        <div class="portal-symbol">R</div>
        <h3>项目复现</h3>
        <p>整理环境搭建、代码结构、训练过程、失败原因和阶段结论。</p>
        <small>PROJECTS / REPRODUCTION</small>
      </a>
    </div>
  </section>

  {lead && (
    <section class="latest-section shell">
      <SectionHeader eyebrow="02 / LATEST" title="近期更新" description="最近发布的论文解读、Agent 实践与项目复现记录。" href="/search/" linkLabel="搜索全部内容" />
      <div class="editorial-grid">
        <a class={`lead-story ${lead.collection}`} href={entryUrl(lead.collection, lead.entry.id)}>
          <div class="lead-story-head">
            <span>{sectionMeta[lead.collection].label}</span>
            <time datetime={lead.entry.data.pubDate.toISOString()}>{formatDate(lead.entry.data.pubDate)}</time>
          </div>
          <div class="lead-story-index">FEATURED / 01</div>
          <h2>{lead.entry.data.title}</h2>
          <p>{lead.entry.data.description}</p>
          <div class="lead-story-bottom">
            <div>{lead.entry.data.tags?.slice(0, 3).map((tag: string) => <span>{tag}</span>)}</div>
            <b>阅读全文 ↗</b>
          </div>
        </a>

        <div class="secondary-stories">
          {secondary.map(({ entry, collection }, index) => (
            <ArticleCard entry={entry} collection={collection} compact={true} index={index + 1} />
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="closing-panel shell">
    <div class="closing-mark" aria-hidden="true"><span>EAI</span></div>
    <div>
      <span class="closing-kicker">EAI-LAB / 具身智能研究室</span>
      <h2>建立自己的研究脉络，<br />而不是只收藏更多链接。</h2>
      <p>内容将围绕具身智能优质论文、AI Agent 工具实践和机器人项目复现持续更新。</p>
    </div>
    <a class="button inverted" href="/about/">关于这个网站 <span>↗</span></a>
  </section>
</BaseLayout>
