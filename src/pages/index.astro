---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { entryUrl, formatDate, type SectionKey } from '../utils/content';

const filter = ({ data }: { data: { draft?: boolean } }) => import.meta.env.PROD ? data.draft !== true : true;
const sectionKeys: SectionKey[] = ['papers', 'agents', 'projects'];
const collections = await Promise.all(sectionKeys.map((key) => getCollection(key, filter)));

const latestBySection = Object.fromEntries(
  sectionKeys.map((key, index) => [
    key,
    collections[index]
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
      .slice(0, 2)
      .map((entry) => ({
        href: entryUrl(key, entry.id),
        title: entry.data.title,
        description: entry.data.description,
        label: formatDate(entry.data.pubDate)
      }))
  ])
) as Record<SectionKey, Array<{ href: string; title: string; description: string; label: string }>>;

const modules = [
  { href: '/papers/', title: '论文精读', tone: 'paper', latest: latestBySection.papers },
  { href: '/agents/', title: 'Agent 实践', tone: 'agent', latest: latestBySection.agents },
  { href: '/projects/', title: '项目复现', tone: 'project', latest: latestBySection.projects },
  {
    title: '关于这个网站',
    tone: 'about',
    summary: [
      '这是一个具身智能学习与实践记录站。',
      '重点写论文精读、Agent 工程实践、项目复现。',
      '内容优先追求可验证、可复现、可回看。'
    ]
  }
];
---

<BaseLayout>
  <section class="home-lab shell">
    <header class="home-intro">
      <p>EAI-Lab</p>
      <div>
        <h1>具身智能研究室</h1>
        <span>记录具身智能论文精读、Agent 实践和项目复现过程。</span>
      </div>
    </header>

    <section class="home-index" aria-label="首页入口">
      {modules.map((item) => (
        <article class:list={['home-module', item.tone]}>
          {item.href ? (
            <a class="home-module-title" href={item.href} aria-label={`进入${item.title}`}>
              <h2>{item.title}</h2>
              <span aria-hidden="true">↗</span>
            </a>
          ) : (
            <div class="home-module-title static">
              <h2>{item.title}</h2>
            </div>
          )}

          {item.latest ? (
            <div class="home-latest-list">
              {item.latest.map((entry) => (
                <a class="home-latest-item" href={entry.href} aria-label={`阅读：${entry.title}`}>
                  <span>{entry.label}</span>
                  <strong>{entry.title}</strong>
                  <p>{entry.description}</p>
                </a>
              ))}
            </div>
          ) : (
            <div class="home-about-note">
              {item.summary.map((line) => <p>{line}</p>)}
            </div>
          )}
        </article>
      ))}
    </section>
  </section>
</BaseLayout>
