---
import BaseLayout from '../layouts/BaseLayout.astro';

const modules = [
  { href: '/papers/', title: '论文精读', tone: 'paper' },
  { href: '/agents/', title: 'Agent 实践', tone: 'agent' },
  { href: '/projects/', title: '项目复现', tone: 'project' },
  { href: '/about/', title: '关于这个网站', tone: 'about' }
];
---

<BaseLayout>
  <section class="home-lab shell">
    <div class="home-field" aria-hidden="true">
      <span class="field-frame"></span>
      <span class="field-axis axis-a"></span>
      <span class="field-axis axis-b"></span>
      <span class="field-axis axis-c"></span>
      <span class="field-panel panel-a"></span>
      <span class="field-panel panel-b"></span>
      <span class="field-panel panel-c"></span>
      <span class="field-node node-a"></span>
      <span class="field-node node-b"></span>
      <span class="field-node node-c"></span>
      <span class="field-node node-d"></span>
    </div>

    <nav class="home-index" aria-label="首页入口">
      {modules.map((item) => (
        <a class:list={['home-module', item.tone]} href={item.href} aria-label={`进入${item.title}`}>
          <h2>{item.title}</h2>
          <span aria-hidden="true">↗</span>
        </a>
      ))}
    </nav>
  </section>
</BaseLayout>
