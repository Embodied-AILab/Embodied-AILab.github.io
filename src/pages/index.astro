---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { entryUrl, formatDate } from '../utils/content';
import { researchDirections } from '../data/researchDirections';
import RepoStarTrend from '../components/RepoStarTrend.astro';

const filter = ({ data }: { data: { draft?: boolean } }) => import.meta.env.PROD ? data.draft !== true : true;
const [research, projects] = await Promise.all([
  getCollection('research', filter),
  getCollection('projects', filter)
]);

const latestByDirection = Object.fromEntries(
  researchDirections.map((direction) => [
    direction.slug,
    research
      .filter((entry) => entry.data.direction === direction.slug)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
      .slice(0, 2)
      .map((entry) => ({
        href: entryUrl('research', entry.id),
        title: entry.data.title,
        description: entry.data.description,
        label: formatDate(entry.data.pubDate)
      }))
  ])
) as Record<string, Array<{ href: string; title: string; description: string; label: string }>>;

const directionCards = researchDirections.map((direction, index) => {
  const latest = latestByDirection[direction.slug] ?? [];
  return {
    ...direction,
    index: String(index + 1).padStart(2, '0'),
    count: research.filter((entry) => entry.data.direction === direction.slug).length,
    latest: latest[0]
  };
});

const latestResearch = research
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4)
  .map((entry) => ({
    href: entryUrl('research', entry.id),
    title: entry.data.title,
    description: entry.data.description,
    label: formatDate(entry.data.pubDate)
  }));

const latestProjects = projects
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)
  .map((entry) => ({
    href: entryUrl('projects', entry.id),
    title: entry.data.title,
    description: entry.data.description,
    label: formatDate(entry.data.pubDate)
  }));

const homeStats = [
  { label: '研究方向', value: String(researchDirections.length).padStart(2, '0') },
  { label: '研究笔记', value: String(research.length).padStart(2, '0') },
  { label: '项目复现', value: String(projects.length).padStart(2, '0') },
  { label: '最近更新', value: latestResearch[0]?.label ?? '整理中' }
];

const heroVisuals = [
  {
    src: '/notes/deep-whole-body-parkour/cover.webp',
    alt: '人形机器人全身跑酷动作合集',
    label: 'Vision Parkour'
  },
  {
    src: '/notes/hiking-in-the-wild/system-overview.webp',
    alt: 'Hiking in the Wild 系统总览',
    label: 'Perceptive AMP'
  },
  {
    src: '/notes/open-motion-control/image_05.png',
    alt: '世界模型训练流程',
    label: 'World Model'
  }
];
---

<BaseLayout>
  <section class="home-lab shell">
    <section class="home-hero" aria-label="EAI-Lab 主页">
      <div class="home-hero-copy">
        <p class="home-eyebrow">EAI-Lab · Embodied AI Notes</p>
        <h1>具身智能研究室</h1>
        <p class="home-deck">按技术问题整理机器人运动控制、视觉强化学习、AMP、世界模型与项目复现，把论文里的算法流程拆成能复用的工程笔记。</p>
        <div class="home-hero-actions">
          <a class="button primary" href="/directions/">进入研究方向 <span>↗</span></a>
          <a class="button ghost" href="/search/">站内搜索 <span>↗</span></a>
        </div>
      </div>

      <div class="home-hero-side" aria-label="最近研究动态">
        <div class="home-side-head">
          <span>Latest Notes</span>
          <a href="/directions/">全部方向 ↗</a>
        </div>
        <div class="home-side-list">
          {latestResearch.slice(0, 3).map((entry, index) => (
            <a href={entry.href}>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <strong>{entry.title}</strong>
              <small>{entry.label}</small>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="home-stats" aria-label="站点统计">
      {homeStats.map((item) => (
        <div>
          <strong>{item.value}</strong>
          <span>{item.label}</span>
        </div>
      ))}
    </section>

    <section class="home-visual-strip" aria-label="研究图像索引">
      {heroVisuals.map((item) => (
        <figure>
          <img src={item.src} alt={item.alt} loading="lazy" />
          <figcaption>{item.label}</figcaption>
        </figure>
      ))}
    </section>

    <section class="home-section-heading">
      <div>
        <span>Research Map</span>
        <h2>全部研究方向</h2>
      </div>
      <p>一眼看到当前分类和每个方向的最新笔记，后续新增文章会自动回流到对应方向。</p>
    </section>

    <section class="home-category-board" aria-label="研究方向分类">
      <div class="home-category-grid">
        {directionCards.map((item) => (
          <a class="home-category-card" style={`--module-color: ${item.color}`} href={`/directions/${item.slug}/`} aria-label={`进入${item.label}`}>
            <div class="home-category-meta">
              <span>{item.index}</span>
              <i>{item.count > 0 ? `${item.count} 篇` : '整理中'}</i>
            </div>
            <h2>{item.label}</h2>
            <p>{item.description}</p>
            {item.latest && (
              <strong>
                <span>{item.latest.label}</span>
                {item.latest.title}
              </strong>
            )}
          </a>
        ))}
      </div>
    </section>

    <section class="home-updates" aria-label="最近更新">
      <article class="home-update-panel">
        <div class="home-panel-head">
          <h2>最新研究笔记</h2>
          <a href="/directions/">研究方向 <span>↗</span></a>
        </div>
        <div class="home-update-list">
          {latestResearch.map((entry) => (
            <a class="home-update-item" href={entry.href} aria-label={`阅读：${entry.title}`}>
              <span>{entry.label}</span>
              <strong>{entry.title}</strong>
              <p>{entry.description}</p>
            </a>
          ))}
        </div>
      </article>

      <article class="home-update-panel">
        <div class="home-panel-head">
          <h2>项目复现</h2>
          <a href="/projects/">全部项目 <span>↗</span></a>
        </div>
        <div class="home-update-list">
          {latestProjects.map((entry) => (
            <a class="home-update-item" href={entry.href} aria-label={`阅读：${entry.title}`}>
              <span>{entry.label}</span>
              <strong>{entry.title}</strong>
              <p>{entry.description}</p>
            </a>
          ))}
        </div>
      </article>

      <RepoStarTrend compact />
    </section>
  </section>
</BaseLayout>
