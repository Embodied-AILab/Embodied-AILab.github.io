---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { entryUrl, formatDate } from '../utils/content';
import { researchDirections } from '../data/researchDirections';
import RepoStarTrend from '../components/RepoStarTrend.astro';

const filter = ({ data }: { data: { draft?: boolean } }) => import.meta.env.PROD ? data.draft !== true : true;
const [research, projects] = await Promise.all([
  getCollection('research', filter),
  getCollection('projects', filter)
]);

const latestResearch = research
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4)
  .map((entry) => ({
    href: entryUrl('research', entry.id),
    title: entry.data.title,
    description: entry.data.description,
    label: formatDate(entry.data.pubDate)
  }));

const homeStats = [
  { label: '研究方向', value: String(researchDirections.length).padStart(2, '0') },
  { label: '研究笔记', value: String(research.length).padStart(2, '0') },
  { label: '项目复现', value: String(projects.length).padStart(2, '0') },
  { label: '最近更新', value: latestResearch[0]?.label ?? '整理中' }
];

const allEntries = [...research, ...projects];
const updateCounts = new Map<string, number>();
allEntries.forEach((entry) => {
  const date = entry.data.pubDate.toISOString().slice(0, 10);
  updateCounts.set(date, (updateCounts.get(date) ?? 0) + 1);
});

const latestDate = allEntries
  .map((entry) => entry.data.pubDate)
  .sort((a, b) => b.valueOf() - a.valueOf())[0] ?? new Date();
const endDate = new Date(latestDate);
endDate.setHours(0, 0, 0, 0);
endDate.setDate(endDate.getDate() + (6 - endDate.getDay()));
const startDate = new Date(endDate);
startDate.setDate(endDate.getDate() - 83);

const contributionDays = Array.from({ length: 84 }, (_, index) => {
  const date = new Date(startDate);
  date.setDate(startDate.getDate() + index);
  const key = date.toISOString().slice(0, 10);
  const count = updateCounts.get(key) ?? 0;
  const level = count === 0 ? 0 : Math.min(count, 4);
  return {
    date: formatDate(date),
    count,
    level
  };
});

const activeDays = contributionDays.filter((day) => day.count > 0).length;
---

<BaseLayout>
  <section class="home-lab shell">
    <section class="home-hero" aria-label="EAI-Lab 主页">
      <div class="home-hero-copy">
        <p class="home-eyebrow">EAI-Lab · Embodied AI Notes</p>
        <h1>具身智能研究室</h1>
        <p class="home-deck">按技术问题整理机器人运动控制、视觉强化学习、AMP、世界模型与项目复现，把论文里的算法流程拆成能复用的工程笔记。</p>
        <div class="home-hero-actions">
          <a class="button primary" href="/directions/">进入研究方向 <span>↗</span></a>
          <a class="button ghost" href="/search/">站内搜索 <span>↗</span></a>
        </div>
      </div>

      <div class="home-hero-side" aria-label="最近更新记录">
        <div class="home-side-head">
          <span>更新记录</span>
          <a href="/directions/">全部内容 ↗</a>
        </div>
        <div class="home-contrib-card">
          <div class="home-contrib-summary">
            <strong>{allEntries.length}</strong>
            <span>最近内容记录</span>
          </div>
          <div class="home-contrib-grid" aria-label="最近 12 周内容更新热力图">
            {contributionDays.map((day) => (
              <span data-level={day.level} title={`${day.date}：${day.count} 条更新`} aria-label={`${day.date}：${day.count} 条更新`}></span>
            ))}
          </div>
          <div class="home-contrib-foot">
            <span>{activeDays} 天有更新</span>
            <i>少</i>
            <b data-level="1"></b>
            <b data-level="2"></b>
            <b data-level="3"></b>
            <b data-level="4"></b>
            <i>多</i>
          </div>
        </div>
      </div>
    </section>

    <section class="home-stats" aria-label="站点统计">
      {homeStats.map((item) => (
        <div>
          <strong>{item.value}</strong>
          <span>{item.label}</span>
        </div>
      ))}
    </section>

    <section class="home-star-section" aria-label="GitHub Star">
      <RepoStarTrend compact />
    </section>
  </section>
</BaseLayout>
