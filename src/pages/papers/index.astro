---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const entries = (await getCollection('papers', ({ data }) => import.meta.env.PROD ? data.draft !== true : true))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="论文精读" description="从研究问题出发，拆解核心方法、训练流程、实验设计与实现细节。">
  <section class="listing-hero shell">
    <div class="listing-index">01</div>
    <h1>论文精读</h1>
    <p>从研究问题出发，拆解核心方法、训练流程、实验设计与实现细节。</p>
    <div class="listing-meta"><span>{String(entries.length).padStart(2, '0')} 篇内容</span><i></i><span>具身智能 · 人形机器人 · 机器人学习</span></div>
  </section>

  <section class="shell listing-section">
    <div class="article-grid-list">
      {entries.map((entry, index) => <ArticleCard entry={entry} collection="papers" index={index} />)}
    </div>
    {entries.length === 0 && <div class="empty-state">内容正在整理中。</div>}
  </section>
</BaseLayout>
