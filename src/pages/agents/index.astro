---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const entries = (await getCollection('agents', ({ data }) => import.meta.env.PROD ? data.draft !== true : true))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="AI Agent / Vibe Coding" description="记录智能工具在读论文、写代码、项目复现和知识生产中的真实用法。">
  <section class="listing-hero shell">
    <div class="listing-index">02</div>
    <h1>AI Agent /<br />Vibe Coding</h1>
    <p>记录智能工具在读论文、写代码、项目复现和知识生产中的真实用法。</p>
    <div class="listing-meta"><span>{String(entries.length).padStart(2, '0')} 篇内容</span><i></i><span>智能工具 · 工作流 · 编程实践</span></div>
  </section>

  <section class="shell listing-section">
    <div class="article-grid-list">
      {entries.map((entry, index) => <ArticleCard entry={entry} collection="agents" index={index} />)}
    </div>
    {entries.length === 0 && <div class="empty-state">内容正在整理中。</div>}
  </section>
</BaseLayout>
