---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { entryUrl, sectionMeta } from '../utils/content';

const filter = ({ data }: any) => import.meta.env.PROD ? data.draft !== true : true;
const [papers, agents, projects] = await Promise.all([
  getCollection('papers', filter),
  getCollection('agents', filter),
  getCollection('projects', filter)
]);

const searchData = [
  ...papers.map((entry) => ({ entry, collection: 'papers' as const })),
  ...agents.map((entry) => ({ entry, collection: 'agents' as const })),
  ...projects.map((entry) => ({ entry, collection: 'projects' as const }))
].map(({ entry, collection }) => ({
  title: entry.data.title,
  description: entry.data.description,
  tags: entry.data.tags ?? [],
  body: entry.body.slice(0, 12000),
  category: sectionMeta[collection].label,
  url: entryUrl(collection, entry.id),
  timestamp: entry.data.pubDate.valueOf(),
  date: entry.data.pubDate.toISOString().slice(0, 10)
})).sort((a, b) => b.timestamp - a.timestamp);

const serialized = JSON.stringify(searchData).replace(/</g, '\\u003c');
---

<BaseLayout title="站内搜索" description="搜索 EAI-Lab 的论文精读、Agent 实践与项目复现内容。">
  <section class="search-page container">
    <div class="section-eyebrow">SEARCH</div>
    <h1>站内搜索</h1>
    <p>可搜索标题、摘要、标签与正文内容。</p>

    <div class="search-box">
      <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="6.7"></circle><path d="m16 16 4.2 4.2"></path></svg>
      <input id="search-input" type="search" placeholder="搜索论文、算法、工具或项目…" autocomplete="off" autofocus />
      <kbd>/</kbd>
    </div>

    <div class="search-status" id="search-status"></div>
    <div class="search-results" id="search-results" aria-live="polite"></div>
    <script id="search-data" type="application/json" set:html={serialized}></script>
  </section>
</BaseLayout>

<script>
  const input = document.querySelector('#search-input');
  const results = document.querySelector('#search-results');
  const status = document.querySelector('#search-status');
  const dataNode = document.querySelector('#search-data');
  const items = dataNode ? JSON.parse(dataNode.textContent || '[]') : [];

  const normalize = (value) => String(value || '').toLowerCase().replace(/\s+/g, ' ').trim();

  function render(query = '') {
    if (!results || !status) return;
    const terms = normalize(query).split(' ').filter(Boolean);
    const matches = items.filter((item) => {
      const haystack = normalize([item.title, item.description, item.tags.join(' '), item.body].join(' '));
      return terms.every((term) => haystack.includes(term));
    });

    status.textContent = query ? `找到 ${matches.length} 条结果` : `共收录 ${items.length} 篇内容`;
    results.textContent = '';

    if (matches.length === 0) {
      const empty = document.createElement('div');
      empty.className = 'empty-state';
      empty.textContent = '没有找到匹配内容，请尝试更短的关键词。';
      results.appendChild(empty);
      return;
    }

    matches.slice(0, 30).forEach((item) => {
      const card = document.createElement('a');
      card.className = 'search-result-card';
      card.href = item.url;

      const meta = document.createElement('div');
      meta.className = 'search-result-meta';
      meta.textContent = `${item.category} · ${item.date}`;

      const title = document.createElement('h2');
      title.textContent = item.title;

      const desc = document.createElement('p');
      desc.textContent = item.description;

      const tags = document.createElement('div');
      tags.className = 'card-tags';
      item.tags.slice(0, 4).forEach((tag) => {
        const span = document.createElement('span');
        span.textContent = tag;
        tags.appendChild(span);
      });

      card.append(meta, title, desc, tags);
      results.appendChild(card);
    });
  }

  input?.addEventListener('input', (event) => render(event.target.value));
  document.addEventListener('keydown', (event) => {
    if (event.key === '/' && document.activeElement !== input) {
      event.preventDefault();
      input?.focus();
    }
  });
  render('');
</script>
