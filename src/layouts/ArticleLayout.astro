---
import BaseLayout from './BaseLayout.astro';
import { sectionMeta, type SectionKey } from '../utils/content';
import { getResearchDirection } from '../data/researchDirections';
import VisitorCounter from '../components/VisitorCounter.astro';

interface Props {
  entry: any;
  collection: SectionKey;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  minutes: number;
}

const { entry, collection, headings = [] } = Astro.props;
const meta = sectionMeta[collection];
const data = entry.data;
const direction = collection === 'research' ? getResearchDirection(data.direction) : undefined;
const sectionHref = collection === 'research' ? '/directions/' : `/${collection}/`;
const categoryHref = direction ? `/directions/${direction.slug}/` : sectionHref;
const categoryLabel = direction?.label ?? meta.label;
const visibleHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<BaseLayout title={data.title} description={data.description} image={data.cover}>
  <div class="article-page shell">
    <nav class="breadcrumb" aria-label="面包屑">
      <a href="/">首页</a><span>→</span><a href={sectionHref}>{meta.label}</a>
      {direction && <><span>→</span><a href={categoryHref}>{direction.label}</a></>}
    </nav>

    <header class="article-header">
      <div class="article-kicker"><span>{categoryLabel}</span></div>
      <h1>{data.title}</h1>
      <p class="article-deck">{data.description}</p>

      {data.tags?.length > 0 && (
        <div class="tag-row" aria-label="文章标签">
          {data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
      )}

      {(data.paperUrl || data.projectUrl || data.codeUrl || data.repoUrl) && (
        <div class="article-actions">
          {data.paperUrl && <a class="button primary small" href={data.paperUrl} target="_blank" rel="noreferrer">论文原文 <span>↗</span></a>}
          {data.projectUrl && <a class="button ghost small" href={data.projectUrl} target="_blank" rel="noreferrer">项目主页 <span>↗</span></a>}
          {data.codeUrl && <a class="button ghost small" href={data.codeUrl} target="_blank" rel="noreferrer">开源代码 <span>↗</span></a>}
          {data.repoUrl && <a class="button ghost small" href={data.repoUrl} target="_blank" rel="noreferrer">项目仓库 <span>↗</span></a>}
        </div>
      )}
    </header>

    <div class="article-divider"><span></span><i></i></div>

    <div class="article-layout">
      <div class="article-main-column">
        <article class="prose"><slot /></article>
      </div>

      <aside class="article-sidebar" aria-label="文章侧边栏">
        {visibleHeadings.length > 0 && (
          <nav class="toc" aria-label="本页目录">
            <div class="toc-title">本页目录</div>
            <ol>
              {visibleHeadings.map((heading) => (
                <li class:list={[heading.depth === 3 && 'toc-sub']}>
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
              ))}
            </ol>
          </nav>
        )}
        <VisitorCounter />
      </aside>
    </div>
  </div>
</BaseLayout>
