---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
}

const {
  title = 'EAI-Lab｜具身智能研究室',
  description = '具身智能论文精读、AI Agent / Vibe Coding 实践与项目复现。',
  image = '/avatar.jpg',
  noIndex = false
} = Astro.props;

const fullTitle = title.includes('EAI-Lab') ? title : `${title}｜EAI-Lab`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const socialImage = new URL(image, Astro.site ?? Astro.url.origin);
const ambientParticles = Array.from({ length: 34 }, (_, index) => ({
  x: (index * 29 + 7) % 100,
  delay: (index * 13 + 3) % 22,
  duration: 11 + ((index * 7) % 11),
  scale: 0.75 + ((index * 5) % 7) * 0.13,
  drift: (index * 17 + 11) % 100
}));
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#eef3ef" />
    {noIndex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/jpeg" href="/avatar.jpg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{fullTitle}</title>
    <script is:inline>
      (() => {
        const key = 'embodied-ailab-theme';
        const saved = localStorage.getItem(key);
        const theme = saved === 'dark' || saved === 'light'
          ? saved
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;

        const effectsKey = 'embodied-ailab-ambient-effects';
        const legacyKey = 'embodied-ailab-ambient';
        const effectKeys = ['snow', 'rain', 'sakura'];
        const savedEffects = localStorage.getItem(effectsKey);
        const legacyEffect = localStorage.getItem(legacyKey);
        const activeEffects = savedEffects
          ? savedEffects.split(',').filter((item) => effectKeys.includes(item))
          : (effectKeys.includes(legacyEffect) ? [legacyEffect] : []);
        effectKeys.forEach((item) => {
          const attr = `ambient${item[0].toUpperCase()}${item.slice(1)}`;
          document.documentElement.dataset[attr] = activeEffects.includes(item) ? 'on' : 'off';
        });
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">跳到正文</a>
    <div class="ambient-layer ambient-layer-snow" aria-hidden="true">
      {ambientParticles.map((item) => (
        <span style={`--x:${item.x}%; --delay:-${item.delay}s; --duration:${item.duration}s; --scale:${item.scale}; --drift:${item.drift - 50}px;`}></span>
      ))}
    </div>
    <div class="ambient-layer ambient-layer-rain" aria-hidden="true">
      {ambientParticles.map((item) => (
        <span style={`--x:${item.x}%; --delay:-${item.delay}s; --duration:${item.duration}s; --scale:${item.scale}; --drift:${item.drift - 50}px;`}></span>
      ))}
    </div>
    <div class="ambient-layer ambient-layer-sakura" aria-hidden="true">
      {ambientParticles.map((item) => (
        <span style={`--x:${item.x}%; --delay:-${item.delay}s; --duration:${item.duration}s; --scale:${item.scale}; --drift:${item.drift - 50}px;`}></span>
      ))}
    </div>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
