---
const path = Astro.url.pathname;
const navItems = [
  { href: '/papers/', label: '论文精读' },
  { href: '/agents/', label: 'Agent 实践' },
  { href: '/projects/', label: '项目复现' },
  { href: '/about/', label: '关于' }
];
const isActive = (href: string) => path === href || (path.startsWith(href) && href !== '/');
---

<header class="site-header">
  <div class="header-inner shell">
    <a class="brand" href="/" aria-label="EAI-Lab 首页">
      <span class="brand-avatar" aria-hidden="true">
        <img src="/avatar.jpg" alt="" />
      </span>
      <span class="brand-copy">
        <strong>EAI-Lab</strong>
        <small>具身智能研究室</small>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="主导航">
      {navItems.map((item) => (
        <a class:list={[isActive(item.href) && 'active']} href={item.href}>
          <span>{item.label}</span>
        </a>
      ))}
    </nav>

    <div class="header-tools">
      <a class:list={['icon-button', 'search-button', path === '/search/' && 'active']} href="/search/" aria-label="站内搜索">
        <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="10.8" cy="10.8" r="6.2"></circle><path d="m15.4 15.4 4.3 4.3"></path></svg>
      </a>

      <button class="theme-toggle" id="theme-toggle" type="button" aria-label="切换到深色模式" title="切换深浅色模式">
        <span class="theme-track" aria-hidden="true">
          <svg class="sun" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3.6"></circle><path d="M12 2.5v2.1M12 19.4v2.1M4.6 4.6l1.5 1.5M17.9 17.9l1.5 1.5M2.5 12h2.1M19.4 12h2.1M4.6 19.4l1.5-1.5M17.9 6.1l1.5-1.5"></path></svg>
          <svg class="moon" viewBox="0 0 24 24"><path d="M20 15.1A8.2 8.2 0 0 1 8.9 4 8.6 8.6 0 1 0 20 15.1Z"></path></svg>
          <span class="theme-knob"></span>
        </span>
      </button>

      <details class="mobile-menu">
        <summary aria-label="打开导航菜单"><span></span><span></span><span></span></summary>
        <div class="mobile-menu-panel">
          {navItems.map((item) => <a class:list={[isActive(item.href) && 'active']} href={item.href}>{item.label}</a>)}
          <a href="/search/">站内搜索</a>
        </div>
      </details>
    </div>
  </div>
</header>

<div class="ambient-dock" id="ambient-dock" role="group" aria-label="背景效果开关">
  <button type="button" data-ambient-toggle="snow" aria-label="开启雪花背景" title="雪花">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v18M5.6 6.2l12.8 11.6M18.4 6.2 5.6 17.8M7.4 3.8 12 8l4.6-4.2M7.4 20.2 12 16l4.6 4.2M3.6 9.6 8.9 11 7.4 5.8M20.4 14.4 15.1 13l1.5 5.2M20.4 9.6 15.1 11l1.5-5.2M3.6 14.4 8.9 13l-1.5 5.2"></path></svg>
  </button>
  <button type="button" data-ambient-toggle="rain" aria-label="开启小雨背景" title="小雨">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.5 4.5 5.8 9M13 3.8l-2.2 5.9M18.4 5.2l-1.7 4.6M8.7 13.1l-2.4 6.2M14.2 12.1l-2.6 7M19.3 13.7l-2.1 5.5"></path></svg>
  </button>
  <button type="button" data-ambient-toggle="sakura" aria-label="开启樱花背景" title="樱花">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 11.8c-2.4-3.2-2.1-6.6 0-8.3 2.1 1.7 2.4 5.1 0 8.3Z"></path><path d="M12.1 12c3.8-1.2 6.9.4 7.5 3.1-2.3 1.4-5.7.6-7.5-3.1Z"></path><path d="M11.9 12c-1.8 3.7-5.2 4.5-7.5 3.1.6-2.7 3.7-4.3 7.5-3.1Z"></path><path d="M12 12.2c1.4 3.8 0 6.9-2.6 7.8-1.7-2.1-1.1-5.6 2.6-7.8Z"></path><path d="M12 12.2c3.7 2.2 4.3 5.7 2.6 7.8-2.6-.9-4-4-2.6-7.8Z"></path><circle cx="12" cy="12" r="1.4"></circle></svg>
  </button>
</div>

<script is:inline>
  (() => {
    const key = 'embodied-ailab-theme';
    const root = document.documentElement;
    const button = document.getElementById('theme-toggle');
    const meta = document.querySelector('meta[name="theme-color"]');
    const ambientKey = 'embodied-ailab-ambient-effects';
    const legacyAmbientKey = 'embodied-ailab-ambient';
    const ambientButtons = document.querySelectorAll('[data-ambient-toggle]');
    const ambientKeys = ['snow', 'rain', 'sakura'];
    const ambientNames = {
      snow: '雪花',
      rain: '小雨',
      sakura: '樱花'
    };

    const apply = (theme) => {
      root.dataset.theme = theme;
      root.style.colorScheme = theme;
      localStorage.setItem(key, theme);
      if (button) button.setAttribute('aria-label', theme === 'dark' ? '切换到浅色模式' : '切换到深色模式');
      if (meta) meta.setAttribute('content', theme === 'dark' ? '#0d0f12' : '#eef3ef');
    };

    const attrName = (name) => `ambient${name[0].toUpperCase()}${name.slice(1)}`;

    const readAmbient = () => {
      const saved = localStorage.getItem(ambientKey);
      const legacy = localStorage.getItem(legacyAmbientKey);
      if (saved) return saved.split(',').filter((item) => ambientKeys.includes(item));
      return ambientKeys.includes(legacy) ? [legacy] : [];
    };

    const applyAmbient = (activeEffects) => {
      const active = ambientKeys.filter((item) => activeEffects.includes(item));
      ambientKeys.forEach((item) => {
        root.dataset[attrName(item)] = active.includes(item) ? 'on' : 'off';
      });
      localStorage.setItem(ambientKey, active.join(','));
      ambientButtons.forEach((item) => {
        const option = item.dataset.ambientToggle;
        const enabled = active.includes(option);
        item.classList.toggle('active', enabled);
        item.setAttribute('aria-pressed', String(enabled));
        item.setAttribute('aria-label', `${enabled ? '关闭' : '开启'}${ambientNames[option]}背景`);
      });
    };

    button?.addEventListener('click', () => apply(root.dataset.theme === 'dark' ? 'light' : 'dark'));
    applyAmbient(readAmbient());
    ambientButtons.forEach((item) => {
      item.addEventListener('click', () => {
        const active = ambientKeys.filter((key) => root.dataset[attrName(key)] === 'on');
        const option = item.dataset.ambientToggle;
        applyAmbient(active.includes(option)
          ? active.filter((value) => value !== option)
          : [...active, option]);
      });
    });
  })();
</script>
