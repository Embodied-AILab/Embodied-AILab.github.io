---
import RepoStarTrend from './RepoStarTrend.astro';

interface Props {
  entryId: string;
}

const { entryId } = Astro.props;
---

<section class="article-reactions" data-article-reactions data-entry-id={entryId} aria-label="文章反馈">
  <article class="article-like-card">
    <button class="article-like-button" type="button" data-like-button aria-pressed="false">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 20.4s-7.2-4.2-9.2-9.2C1.5 7.9 3.5 5 6.8 5c1.8 0 3.1.9 4 2.2C11.7 5.9 13 5 14.8 5c3.3 0 5.3 2.9 4 6.2C19.2 16.2 12 20.4 12 20.4Z"></path>
      </svg>
      <span data-like-label>点个爱心</span>
      <strong data-like-count>0</strong>
    </button>
    <p>本机收藏</p>
  </article>

  <RepoStarTrend compact />
</section>

<script is:inline>
  (() => {
    const storeKey = 'embodied-ailab-liked-articles';

    const readStore = () => {
      try {
        const parsed = JSON.parse(localStorage.getItem(storeKey) || '{}');
        return parsed && typeof parsed === 'object' ? parsed : {};
      } catch {
        return {};
      }
    };

    const writeStore = (store) => {
      localStorage.setItem(storeKey, JSON.stringify(store));
    };

    document.querySelectorAll('[data-article-reactions]').forEach((root) => {
      if (root.dataset.likeReady === 'true') return;
      root.dataset.likeReady = 'true';

      const entryId = root.dataset.entryId;
      const button = root.querySelector('[data-like-button]');
      const label = root.querySelector('[data-like-label]');
      const count = root.querySelector('[data-like-count]');

      const render = () => {
        const store = readStore();
        const liked = store[entryId] === true;
        root.classList.toggle('is-liked', liked);
        button.setAttribute('aria-pressed', String(liked));
        label.textContent = liked ? '已点爱心' : '点个爱心';
        count.textContent = liked ? '1' : '0';
      };

      button.addEventListener('click', () => {
        const store = readStore();
        store[entryId] = store[entryId] !== true;
        writeStore(store);
        render();
      });

      render();
    });
  })();
</script>
