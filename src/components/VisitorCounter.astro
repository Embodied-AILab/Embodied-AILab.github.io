---
const counterId = '1782567688';
const counterSrc = `https://smallcounter.com/count.php?count_value=&c_style=4&id=${counterId}`;
const counterHref = `https://smallcounter.com/cc_stats/${counterId}/`;
---

<section class="visitor-counter" aria-label="点击量统计">
  <span class="visitor-counter-label">点击量</span>
  <a class="visitor-counter-count" href={counterHref} target="_blank" rel="noreferrer" aria-label="查看点击量统计">
    <img
      src={counterSrc}
      loading="lazy"
      decoding="async"
      referrerpolicy="no-referrer-when-downgrade"
      alt="SmallCounter page view count"
    />
  </a>
  <span>tracked by SmallCounter</span>
</section>
